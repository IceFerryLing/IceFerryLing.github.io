---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_NAME, SITE_URL } from '../config/site';
import LeftSidebar from '../components/LeftSidebar.astro';

// 布局支持页面级 SEO 覆盖；未传参时使用站点默认值
const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  image = '/assets/images/hero-purple.svg',
  canonical = '/',
  showSidebar = true
} = Astro.props;
const fullTitle = title === SITE_NAME ? SITE_NAME : `${title} · ${SITE_NAME}`;
const canonicalUrl = new URL(canonical, SITE_URL).toString();
const ogImage = new URL(image, SITE_URL).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <script is:inline>
      (() => {
        // 主题初始化：优先读取用户本地选择，否则跟随系统明暗偏好
        const saved = localStorage.getItem('theme-mode');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const mode = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', mode);
      })();
    </script>
  </head>
  <body class="theme-dark">
    <!-- 顶部阅读进度条 -->
    <div id="readingProgress"></div>
    <!-- 背景动态层：粒子 + 公式泡泡 + 光晕网格 + 侧幕毛玻璃 -->
    <div id="tsparticles" class="particles-layer" aria-hidden="true"></div>
    <div id="formulaBubbles" class="formula-bubbles-layer" aria-hidden="true"></div>
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-grid"></div>
    <div class="side-glass side-glass-left" aria-hidden="true"></div>
    <div class="side-glass side-glass-right" aria-hidden="true"></div>

    <!-- 顶部导航：站点入口 + 主题切换 -->
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/">
          <span class="brand-mark">✦</span>
          <span class="brand-text">{SITE_NAME}</span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <div class="site-nav-links">
            <a href="/" aria-label="首页" title="首页">
              <i class="bi bi-house-door nav-icon" aria-hidden="true"></i>
              <span class="visually-hidden">首页</span>
            </a>
            <a href="/archive/" aria-label="归档" title="归档">
              <i class="bi bi-archive nav-icon" aria-hidden="true"></i>
              <span class="visually-hidden">归档</span>
            </a>
            <a href="/series/" aria-label="系列" title="系列">
              <i class="bi bi-folder2-open nav-icon" aria-hidden="true"></i>
              <span class="visually-hidden">系列</span>
            </a>
            <a href="/about/" aria-label="关于" title="关于">
              <i class="bi bi-person nav-icon" aria-hidden="true"></i>
              <span class="visually-hidden">关于</span>
            </a>
          </div>
          <button id="themeToggle" class="theme-toggle" type="button" aria-label="切换主题">
            <span class="theme-toggle-box" aria-hidden="true">
              <span class="theme-toggle-sky"></span>
              <span class="theme-toggle-stars"></span>
              <span class="theme-toggle-clouds"></span>
              <span class="theme-toggle-halo"></span>
              <span class="theme-toggle-ball">
                <span class="theme-toggle-sun"></span>
                <span class="theme-toggle-moon">
                  <span class="crater crater-1"></span>
                  <span class="crater crater-2"></span>
                  <span class="crater crater-3"></span>
                </span>
              </span>
            </span>
            <span class="visually-hidden">切换主题</span>
          </button>
        </nav>
      </div>
    </header>

    <!-- 主体：左侧信息栏 + 页面内容插槽 -->
    <main class="site-main page-enter" id="pageMain">
      {
        showSidebar ? (
          <div class="layout-shell container">
            <LeftSidebar />
            <section class="content-shell">
              <slot />
            </section>
          </div>
        ) : (
          <section class="container content-shell">
            <slot />
          </section>
        )
      }
    </main>

    <!-- 页脚 -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>© {new Date().getFullYear()} {SITE_NAME} · 紫色星云里记录生活与代码</p>
        <p class="muted">Powered by Astro</p>
      </div>
    </footer>

    <!-- 页面增强脚本：基础增强 + UI 特效 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tsparticles/3.5.0/tsparticles.bundle.min.js"></script>
    <script type="module" src="/assets/js/blog-enhance.js"></script>
    <script type="module" src="/assets/js/ui-effects.js"></script>
  </body>
</html>
