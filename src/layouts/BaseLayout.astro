---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_NAME, SITE_URL } from '../config/site';
import LeftSidebar from '../components/LeftSidebar.astro';

const { title = SITE_NAME, description = SITE_DESCRIPTION, image = '/assets/images/hero-purple.svg', canonical = '/' } = Astro.props;
const fullTitle = title === SITE_NAME ? SITE_NAME : `${title} · ${SITE_NAME}`;
const canonicalUrl = new URL(canonical, SITE_URL).toString();
const ogImage = new URL(image, SITE_URL).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href="/rss.xml" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme-mode');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const mode = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', mode);
      })();
    </script>
  </head>
  <body class="theme-dark">
    <div id="readingProgress"></div>
    <div id="tsparticles" class="particles-layer" aria-hidden="true"></div>
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-grid"></div>

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/">
          <span class="brand-mark">✦</span>
          <span class="brand-text">{SITE_NAME}</span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <div class="site-nav-links">
            <a href="/">首页</a>
            <a href="/archive/">归档</a>
            <a href="/about/">关于</a>
          </div>
          <button id="themeToggle" class="theme-toggle" type="button" aria-label="切换主题">🌙</button>
        </nav>
      </div>
    </header>

    <main class="site-main page-enter" id="pageMain">
      <div class="layout-shell container">
        <LeftSidebar />
        <section class="content-shell">
          <slot />
        </section>
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>© {new Date().getFullYear()} {SITE_NAME} · 紫色星云里记录生活与代码</p>
        <p class="muted">Powered by Astro</p>
      </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/tsparticles/3.5.0/tsparticles.bundle.min.js"></script>
    <script type="module" src="/assets/js/blog-enhance.js"></script>
    <script type="module" src="/assets/js/ui-effects.js"></script>
  </body>
</html>
