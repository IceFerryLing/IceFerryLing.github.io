---
import SeriesTreeBranchItem from './SeriesTreeBranch.astro';
import { seriesSlugToUrl } from '../lib/series';

type SeriesTreeFile = { slug: string; title: string; fileName: string };
type SeriesTreeFolder = { name: string; key: string; folders: SeriesTreeFolder[]; files: SeriesTreeFile[]; total: number };

const { node, seriesKey = '', activeSlug = '', openByDefault = false } = Astro.props as {
  node: SeriesTreeFolder;
  seriesKey?: string;
  activeSlug?: string;
  openByDefault?: boolean;
};
---

<ul class="series-tree-branch">
  {
    node.folders.map((folder) => (
      <li class="series-tree-folder">
        <details class="series-folder" open={openByDefault}>
          <summary>
            <span class="tree-caret" aria-hidden="true"></span>
            <span class="series-folder-name">{folder.name}</span>
            <span class="series-folder-count">{folder.total}</span>
          </summary>
          <SeriesTreeBranchItem node={folder} seriesKey={seriesKey} activeSlug={activeSlug} />
        </details>
      </li>
    ))
  }
  {
    node.files.map((file) => (
      <li class="series-tree-file">
        <a
          class={`series-tree-file-link ${activeSlug === file.slug ? 'is-active' : ''}`}
          href={seriesSlugToUrl(seriesKey, file.slug)}
          data-series-slug={file.slug}
        >
          <span class="series-tree-file-title">{file.title}</span>
        </a>
      </li>
    ))
  }
</ul>
