---
import { pinyin } from 'pinyin-pro';

const { post } = Astro.props;
const baseSearchText = [post.title, post.description, post.excerpt, post.category, ...(post.tags || []), post.date]
  .filter(Boolean)
  .join(' ');

function buildPinyinSearchText(text = '') {
  try {
    const pinyinText = pinyin(String(text), { toneType: 'none', nonZh: 'consecutive' });
    const compact = pinyinText.replace(/\s+/g, '');
    return `${pinyinText} ${compact}`.trim();
  } catch {
    return '';
  }
}

const pinyinSearchText = buildPinyinSearchText(baseSearchText);
const searchText = `${baseSearchText} ${pinyinSearchText}`.trim();
---

<!-- 通用文章卡片：用于首页与归档复用 -->
<article
  class="glass-card post-card p-4 h-100"
  data-category={post.category}
  data-tags={post.tags.join(',')}
  data-search={searchText}
>
  <p class="meta">{post.date}</p>
  <h3 class="post-title">
    <a href={`/posts/${post.slug}/`} class="text-decoration-none">{post.title}</a>
  </h3>
  <p class="post-excerpt">{post.excerpt}</p>
  <div class="post-footer">
    <span class="chip">{post.category}</span>
    <span class="meta">{post.words} words · {post.readingMinutes} min</span>
  </div>
</article>
