---
const { post } = Astro.props;
---

<article class="post-card" data-category={post.category} data-tags={post.tags.join(',')}>
  <p class="post-meta">{post.date}</p>
  <h3><a href={`/posts/${post.slug}/`}>{post.title}</a></h3>
  <p>{post.excerpt}</p>
  <div class="card-foot">
    <span class="chip">{post.category}</span>
    <span class="muted">{post.words} words · {post.readingMinutes} min</span>
  </div>
</article>
