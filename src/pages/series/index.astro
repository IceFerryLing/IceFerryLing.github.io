---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeriesDefinitions, getSeriesTree } from '../../lib/series';

const seriesList = getSeriesDefinitions().map((series) => {
  const { documents } = getSeriesTree(series.key);
  return {
    ...series,
    documentCount: documents.length,
    href: `/series/${encodeURIComponent(series.key)}/`
  };
});
---

<BaseLayout title="系列" description="系列入口页。" canonical="/series/" showSidebar={false}>
  <section class="page-hero">
    <div class="container">
      <h1>系列</h1>
      <p class="page-subtitle">这里把多个目录同时作为系列入口管理。点击某个系列后，会进入它自己的文档树。</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <div class="series-index-grid">
        {
          seriesList.map((series) => (
            <a class="series-index-card glass-card" href={series.href}>
              <h2>{series.title}</h2>
              <p class="muted">{series.description}</p>
              <p class="series-index-meta">{series.documentCount} 篇文档</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
