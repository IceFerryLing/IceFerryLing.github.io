---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesTreeBranch from '../../components/SeriesTreeBranch.astro';
import {
  getSeriesDefinitions,
  getSeriesTree,
  renderSeriesMarkdown,
  seriesSlugToUrl
} from '../../lib/series';

type SeriesTreeFile = { slug: string; title: string; fileName: string };
type SeriesTreeFolder = { name: string; key: string; folders: SeriesTreeFolder[]; files: SeriesTreeFile[]; total: number };

export function getStaticPaths() {
  const definitions = getSeriesDefinitions();
  const paths = [];

  for (const series of definitions) {
    const { documents } = getSeriesTree(series.key);
    paths.push({ params: { slug: series.key } });
    for (const doc of documents) {
      paths.push({ params: { slug: `${series.key}/${doc.slug}` } });
      if (series.key === 'linux-source-code-analyze') {
        paths.push({ params: { slug: doc.slug } });
      }
    }
  }

  return paths;
}

const { slug } = Astro.params;
const slugPath = String(slug || '');
const seriesKeys = new Set(getSeriesDefinitions().map((series) => series.key));
const parts = slugPath.split('/').filter(Boolean);
const firstPart = parts[0] || '';
const hasSeriesPrefix = seriesKeys.has(firstPart);
const seriesKey = hasSeriesPrefix ? firstPart : 'linux-source-code-analyze';
const docSlug = hasSeriesPrefix ? parts.slice(1).join('/') : slugPath;
const { series, root, tree, documents } = getSeriesTree(seriesKey) as {
  series: { key: string; title: string; description: string } | null;
  root: { files: SeriesTreeFile[]; folders: SeriesTreeFolder[] };
  tree: SeriesTreeFolder[];
  documents: Array<{ slug: string; title: string }>;
};
const seriesLabel = series?.title || seriesKey;
const doc = docSlug ? await renderSeriesMarkdown(seriesKey, docSlug) : null;
const firstDocument = documents[0] || null;
const landingDocument = doc || (firstDocument ? await renderSeriesMarkdown(seriesKey, firstDocument.slug) : null);

if (!landingDocument) throw new Error(`Series doc not found: ${slugPath}`);
---

<BaseLayout title={`系列 · ${landingDocument.title}`} description={landingDocument.title} canonical={seriesSlugToUrl(seriesKey, docSlug || landingDocument.slug)} showSidebar={false}>
  <section class="page-hero">
    <div class="container">
      <h1>系列</h1>
      <p class="page-subtitle">{seriesLabel}</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container series-shell">
      <aside class="series-sidebar glass-card">
        <h3 class="series-sidebar-title">{seriesLabel}</h3>
        <div class="tree-toolbar" aria-label="系列树控制">
          <button type="button" class="tree-toolbar-btn" data-tree-action="expand">全部展开</button>
          <button type="button" class="tree-toolbar-btn" data-tree-action="collapse">全部折叠</button>
        </div>
        <ul class="series-tree-root">
          {
            root.files.map((file: SeriesTreeFile) => (
              <li class="series-tree-file">
                <a
                  class={`series-tree-file-link ${landingDocument.slug === file.slug ? 'is-active' : ''}`}
                  href={seriesSlugToUrl(seriesKey, file.slug)}
                  data-series-slug={file.slug}
                >
                  <span class="series-tree-file-title">{file.title}</span>
                </a>
              </li>
            ))
          }
          {
            tree.map((folder: SeriesTreeFolder) => (
              <li class="series-tree-folder">
                <details class="series-folder">
                  <summary>
                    <span class="tree-caret" aria-hidden="true"></span>
                    <span class="series-folder-name">{folder.name}</span>
                    <span class="series-folder-count">{folder.total}</span>
                  </summary>
                  <SeriesTreeBranch node={folder} seriesKey={seriesKey} activeSlug={landingDocument.slug} />
                </details>
              </li>
            ))
          }
        </ul>
      </aside>

      <article class="series-content glass-card">
        <h2 class="series-doc-title">{landingDocument.title}</h2>
        <div class="prose" set:html={landingDocument.html}></div>
      </article>
    </div>
  </section>

  <script is:inline>
    (() => {
      const treeContainer = document.querySelector('.series-sidebar');
      const active = document.querySelector('.series-tree-file-link.is-active');
      const detailsNodes = Array.from(document.querySelectorAll('details.series-folder'));

      const expandBtn = treeContainer?.querySelector('[data-tree-action="expand"]');
      const collapseBtn = treeContainer?.querySelector('[data-tree-action="collapse"]');
      expandBtn?.addEventListener('click', () => detailsNodes.forEach((item) => (item.open = true)));
      collapseBtn?.addEventListener('click', () => detailsNodes.forEach((item) => (item.open = false)));

      if (!active) return;
      let parent = active.parentElement;
      while (parent) {
        if (parent.tagName === 'DETAILS') parent.open = true;
        parent = parent.parentElement;
      }
      active.scrollIntoView({ block: 'nearest' });
    })();
  </script>
</BaseLayout>
