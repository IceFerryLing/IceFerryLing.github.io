---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesTreeBranch from '../../components/SeriesTreeBranch.astro';
import { getSeriesTree, renderSeriesMarkdown } from '../../lib/series';

export function getStaticPaths() {
  const { documents } = getSeriesTree();
  return documents.map((doc) => ({
    params: { slug: doc.slug }
  }));
}

const { slug } = Astro.params;
const slugPath = String(slug || '');
const doc = await renderSeriesMarkdown(slugPath);
if (!doc) throw new Error(`Series doc not found: ${slugPath}`);

const { root, tree } = getSeriesTree();
---

<BaseLayout title={`系列 · ${doc.title}`} description={doc.title} canonical={`/series/${doc.slug}/`} showSidebar={false}>
  <section class="page-hero">
    <div class="container">
      <h1>系列</h1>
      <p class="page-subtitle">Linux 源码分析文档树</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container series-shell">
      <aside class="series-sidebar glass-card">
        <h3 class="series-sidebar-title">linux-source-code-analyze</h3>
        <ul class="series-tree-root">
          {
            root.files.map((file) => (
              <li class="series-tree-file">
                <a
                  class={`series-tree-file-link ${doc.slug === file.slug ? 'is-active' : ''}`}
                  href={`/series/${file.slug}/`}
                  data-series-slug={file.slug}
                >
                  <span class="series-tree-file-title">{file.title}</span>
                </a>
              </li>
            ))
          }
          {
            tree.map((folder) => (
              <li class="series-tree-folder">
                <details class="series-folder">
                  <summary>
                    <span class="series-folder-name">{folder.name}</span>
                    <span class="series-folder-count">{folder.total}</span>
                  </summary>
                  <SeriesTreeBranch node={folder} activeSlug={doc.slug} />
                </details>
              </li>
            ))
          }
        </ul>
      </aside>

      <article class="series-content glass-card">
        <h2 class="series-doc-title">{doc.title}</h2>
        <div class="prose" set:html={doc.html}></div>
      </article>
    </div>
  </section>

  <script is:inline>
    (() => {
      const active = document.querySelector('.series-tree-file-link.is-active');
      if (!active) return;
      let parent = active.parentElement;
      while (parent) {
        if (parent.tagName === 'DETAILS') parent.open = true;
        parent = parent.parentElement;
      }
      active.scrollIntoView({ block: 'nearest' });
    })();
  </script>
</BaseLayout>
