---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSortedPosts } from '../lib/posts';
import ArchiveTreeBranch from '../components/ArchiveTreeBranch.astro';

const posts = getSortedPosts();

function categoryToPath(rawCategory = '') {
  const value = String(rawCategory || '').trim();
  if (!value || value === '未分类') return ['未分类'];
  const parts = value
    .split(/\s*(?:\/|>|｜|\|)\s*/g)
    .map((part) => String(part || '').trim())
    .filter(Boolean);
  return parts.length ? parts : ['未分类'];
}

function createNode(name, key) {
  return { name, key, folders: new Map(), posts: [] };
}

const root = createNode('root', 'root');

for (const post of posts) {
  const path = categoryToPath(post.category);
  let cursor = root;
  let keyPrefix = '';

  for (const segment of path) {
    keyPrefix = keyPrefix ? `${keyPrefix}/${segment}` : segment;
    if (!cursor.folders.has(segment)) {
      cursor.folders.set(segment, createNode(segment, keyPrefix));
    }
    cursor = cursor.folders.get(segment);
  }

  cursor.posts.push({
    slug: post.slug,
    title: post.title,
    date: post.date
  });
}

function finalizeNode(node) {
  const folders = Array.from(node.folders.values())
    .map(finalizeNode)
    .sort((a, b) => a.name.localeCompare(b.name, 'zh-CN'));
  const files = [...node.posts].sort((a, b) => b.date.localeCompare(a.date, 'zh-CN'));
  const total = files.length + folders.reduce((sum, folder) => sum + folder.total, 0);
  return { ...node, folders, posts: files, total };
}

const tree = finalizeNode(root).folders;
---

<BaseLayout title="归档" description="按目录树结构浏览文章。" canonical="/archive/">
  <section class="page-hero">
    <div class="container">
      <h1>归档</h1>
      <p class="page-subtitle">把文章按文件树分组展示，像浏览项目目录一样查看内容。</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <div class="archive-tree-wrap glass-card">
        <ul class="archive-tree-root">
          {
            tree.map((folder) => (
              <li class="archive-tree-folder">
                <details class="archive-folder" open>
                  <summary>
                    <span class="archive-folder-name">{folder.name}</span>
                    <span class="archive-folder-count">{folder.total}</span>
                  </summary>
                  <ArchiveTreeBranch node={folder} />
                </details>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const links = Array.from(document.querySelectorAll('.archive-tree-file-link'));
      const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';
      const slugMatch = currentPath.match(/^\/posts\/([^/]+)$/);
      const currentSlug = slugMatch ? decodeURIComponent(slugMatch[1]) : '';

      function activateLink(link) {
        links.forEach((item) => item.classList.remove('is-active'));
        link.classList.add('is-active');
      }

      function expandAncestors(link) {
        let parent = link.parentElement;
        while (parent) {
          if (parent.tagName === 'DETAILS') {
            parent.open = true;
          }
          parent = parent.parentElement;
        }
      }

      if (currentSlug) {
        const matched = links.find((link) => link.dataset.postSlug === currentSlug);
        if (matched) {
          activateLink(matched);
          expandAncestors(matched);
          matched.scrollIntoView({ block: 'nearest' });
        }
      }

      links.forEach((link) => {
        link.addEventListener('click', () => {
          activateLink(link);
          expandAncestors(link);
        });
      });
    })();
  </script>
</BaseLayout>
