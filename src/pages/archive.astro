---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, getAllCategories, getAllTags } from '../lib/posts';
import { POSTS_PER_PAGE } from '../config/site';

const posts = getSortedPosts();
const categories = getAllCategories(posts);
const tags = getAllTags(posts);
---

<BaseLayout title="归档" description="按分类、标签与关键词筛选文章。" canonical="/archive/">
  <section class="page-hero">
    <div class="container">
      <h1>归档</h1>
      <p class="page-subtitle">把时间轴里的紫色片段收集起来。</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <div class="archive-filter archive-filter-sticky glass-card" id="archiveFilterBar">
        <input id="searchInput" placeholder="搜索标题/摘要..." />
        <select id="categoryFilter">
          <option value="">全部分类</option>
          {categories.map((c) => <option value={c.name}>{c.name} ({c.count})</option>)}
        </select>
        <select id="tagFilter">
          <option value="">全部标签</option>
          {tags.map((t) => <option value={t.name}>{t.name} ({t.count})</option>)}
        </select>
      </div>

      <div id="archiveGrid" class="post-grid row g-4">
        {posts.map((post) => (
          <div class="col-md-6 col-xl-4 archive-post-item">
            <PostCard post={post} />
          </div>
        ))}
      </div>

      <nav class="pagination" id="pager" aria-label="分页"></nav>
    </div>
  </section>

  <script define:vars={{ POSTS_PER_PAGE }}>
    // 归档页：关键词 + 分类 + 标签筛选，并带分页与 URL 参数同步
    const grid = document.getElementById('archiveGrid');
    const pager = document.getElementById('pager');
    const searchInput = document.getElementById('searchInput');
    const categoryFilter = document.getElementById('categoryFilter');
    const tagFilter = document.getElementById('tagFilter');

    if (!grid || !pager || !searchInput || !categoryFilter || !tagFilter) {
      console.warn('[archive] missing filter elements, skip filter init.');
    } else {
    const cards = Array.from(grid.querySelectorAll('.archive-post-item'));

    const normalize = (value = '') => String(value).trim().toLowerCase();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let page = 1;
    let filtered = cards;

    function animateVisibleCards(visibleCards) {
      if (prefersReducedMotion) return;

      visibleCards.forEach((card, index) => {
        card.classList.remove('filter-pop-in');
        card.style.removeProperty('--filter-delay');
        void card.offsetWidth;
        card.style.setProperty('--filter-delay', `${Math.min(index, 10) * 42}ms`);
        card.classList.add('filter-pop-in');
      });
    }

    // 将当前筛选条件写回 URL，方便分享与刷新保持状态
    function updateUrlParams() {
      const params = new URLSearchParams(window.location.search);
      const q = (searchInput.value || '').trim();
      const category = categoryFilter.value;
      const tag = tagFilter.value;

      if (q) params.set('q', q);
      else params.delete('q');

      if (category) params.set('category', category);
      else params.delete('category');

      if (tag) params.set('tag', tag);
      else params.delete('tag');

      if (page > 1) params.set('page', String(page));
      else params.delete('page');

      const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
      history.replaceState(null, '', nextUrl);
    }

    // 首次加载时从 URL 读取筛选参数
    function applyParamsFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q') || '';
      const category = params.get('category') || '';
      const tag = params.get('tag') || '';
      const fromPage = Number(params.get('page'));

      searchInput.value = q;
      if (Array.from(categoryFilter.options).some((o) => o.value === category)) {
        categoryFilter.value = category;
      }
      if (Array.from(tagFilter.options).some((o) => o.value === tag)) {
        tagFilter.value = tag;
      }

      if (Number.isInteger(fromPage) && fromPage > 0) {
        page = fromPage;
      }
    }

    // 执行筛选（可控制是否重置页码）
    function applyFilter({ resetPage = true, animate = true } = {}) {
      const keyword = normalize(searchInput.value || '');
      const category = normalize(categoryFilter.value);
      const tag = normalize(tagFilter.value);

      filtered = cards.filter((card) => {
        const article = card.querySelector('.post-card');
        if (!article) return false;
        const text = normalize(article.dataset.search || card.textContent || '');
        const c = normalize(article.dataset.category || '');
        const tags = (article.dataset.tags || '').split(',').map((t) => normalize(t)).filter(Boolean);
        const hitKeyword = !keyword || text.includes(keyword);
        const hitCategory = !category || c === category;
        const hitTag = !tag || tags.includes(tag);
        return hitKeyword && hitCategory && hitTag;
      });

      if (resetPage) page = 1;
      render({ animate });
    }

    // 渲染分页控件
    function renderPager(totalPages) {
      pager.innerHTML = '';
      if (totalPages <= 1) return;

      const prev = document.createElement('a');
      prev.href = '#';
      prev.textContent = '上一页';
      prev.onclick = (e) => {
        e.preventDefault();
        if (page > 1) {
          page--;
          render();
        }
      };

      const info = document.createElement('span');
      info.className = 'pagination-info';
      info.textContent = `第 ${page} / ${totalPages} 页`;

      const next = document.createElement('a');
      next.href = '#';
      next.textContent = '下一页';
      next.onclick = (e) => {
        e.preventDefault();
        if (page < totalPages) {
          page++;
          render();
        }
      };

      if (page > 1) pager.appendChild(prev);
      pager.appendChild(info);
      if (page < totalPages) pager.appendChild(next);
    }

    // 根据当前页渲染可见卡片
    function render({ animate = true } = {}) {
      const totalPages = Math.max(1, Math.ceil(filtered.length / POSTS_PER_PAGE));
      if (page > totalPages) page = totalPages;
      const start = (page - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;
      const visibleCards = filtered.slice(start, end);

      cards.forEach((card) => (card.style.display = 'none'));
      visibleCards.forEach((card) => (card.style.display = 'block'));

      if (animate) {
        animateVisibleCards(visibleCards);
      }

      renderPager(totalPages);
      updateUrlParams();
    }

    // 事件绑定
    searchInput.addEventListener('input', () => applyFilter({ resetPage: true }));
    categoryFilter.addEventListener('change', () => applyFilter({ resetPage: true }));
    tagFilter.addEventListener('change', () => applyFilter({ resetPage: true }));

    // 初始化流程：先恢复 URL 状态，再执行筛选渲染
    applyParamsFromUrl();
    applyFilter({ resetPage: false, animate: false });
    }
  </script>
</BaseLayout>
