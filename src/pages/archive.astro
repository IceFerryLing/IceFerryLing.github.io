---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, getAllCategories, getAllTags } from '../lib/posts';
import { POSTS_PER_PAGE } from '../config/site';

const posts = getSortedPosts();
const categories = getAllCategories(posts);
const tags = getAllTags(posts);
---

<BaseLayout title="归档" description="按分类、标签与关键词筛选文章。" canonical="/archive/">
  <section class="page-hero">
    <div class="container">
      <h1>归档</h1>
      <p class="page-subtitle">把时间轴里的紫色片段收集起来。</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <div class="archive-filter archive-filter-sticky glass-card" id="archiveFilterBar">
        <label class="filter-field filter-field-search" for="searchInput">
          <span class="filter-field-label">关键词</span>
          <span class="filter-control-wrap">
            <input id="searchInput" placeholder="搜索标题 / 摘要..." aria-label="搜索标题或摘要" />
            <button id="clearSearchBtn" class="clear-search-btn" type="button" aria-label="清空搜索" title="清空搜索">×</button>
          </span>
        </label>

        <label class="filter-field" for="categoryFilter">
          <span class="filter-field-label">分类</span>
          <span class="filter-control-wrap">
            <div class="custom-filter-select" data-native="categoryFilter">
              <button type="button" class="custom-filter-trigger" id="categoryFilterTrigger" aria-haspopup="listbox" aria-expanded="false" aria-controls="categoryFilterMenu">
                <span class="custom-filter-value" id="categoryFilterValue">全部分类</span>
              </button>
              <div class="custom-filter-menu" id="categoryFilterMenu" role="listbox" aria-labelledby="categoryFilterTrigger">
                <button type="button" class="custom-filter-option is-active" data-value="">全部分类</button>
                {categories.map((c) => <button type="button" class="custom-filter-option" data-value={c.name}>{c.name} ({c.count})</button>)}
              </div>
            </div>
            <select id="categoryFilter" class="native-filter-select" aria-label="按分类筛选">
              <option value="">全部分类</option>
              {categories.map((c) => <option value={c.name}>{c.name} ({c.count})</option>)}
            </select>
          </span>
        </label>

        <label class="filter-field" for="tagFilter">
          <span class="filter-field-label">标签</span>
          <span class="filter-control-wrap">
            <div class="custom-filter-select" data-native="tagFilter">
              <button type="button" class="custom-filter-trigger" id="tagFilterTrigger" aria-haspopup="listbox" aria-expanded="false" aria-controls="tagFilterMenu">
                <span class="custom-filter-value" id="tagFilterValue">全部标签</span>
              </button>
              <div class="custom-filter-menu" id="tagFilterMenu" role="listbox" aria-labelledby="tagFilterTrigger">
                <button type="button" class="custom-filter-option is-active" data-value="">全部标签</button>
                {tags.map((t) => <button type="button" class="custom-filter-option" data-value={t.name}>{t.name} ({t.count})</button>)}
              </div>
            </div>
            <select id="tagFilter" class="native-filter-select" aria-label="按标签筛选">
              <option value="">全部标签</option>
              {tags.map((t) => <option value={t.name}>{t.name} ({t.count})</option>)}
            </select>
          </span>
        </label>
      </div>

      <div id="archiveEmptyState" class="archive-empty-state glass-card" hidden>
        <p class="empty-state-title">没有找到匹配内容</p>
        <p class="empty-state-subtitle">换个关键词，或者试试切换分类 / 标签，下一篇也许正好击中你。</p>
      </div>

      <div id="archiveGrid" class="post-grid row g-4">
        {posts.map((post) => (
          <div class="col-md-6 col-xl-4 archive-post-item">
            <PostCard post={post} />
          </div>
        ))}
      </div>

      <nav class="pagination" id="pager" aria-label="分页"></nav>
    </div>
  </section>

  <script define:vars={{ POSTS_PER_PAGE }}>
    // 归档页：关键词 + 分类 + 标签筛选，并带分页与 URL 参数同步
    const grid = document.getElementById('archiveGrid');
    const pager = document.getElementById('pager');
    const searchInput = document.getElementById('searchInput');
    const clearSearchBtn = document.getElementById('clearSearchBtn');
    const categoryFilter = document.getElementById('categoryFilter');
    const tagFilter = document.getElementById('tagFilter');
    const emptyState = document.getElementById('archiveEmptyState');

    if (!grid || !pager || !searchInput || !clearSearchBtn || !categoryFilter || !tagFilter || !emptyState) {
      console.warn('[archive] missing filter elements, skip filter init.');
    } else {
    const cards = Array.from(grid.querySelectorAll('.archive-post-item'));

    const normalize = (value = '') => String(value).trim().toLowerCase();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SEARCH_DEBOUNCE_MS = 220;

    let page = 1;
    let filtered = cards;
    const customSelectRoots = Array.from(document.querySelectorAll('.custom-filter-select'));
    const customSelectSyncFns = [];

    function debounce(fn, wait = 180) {
      let timer = null;
      return (...args) => {
        if (timer) clearTimeout(timer);
        timer = window.setTimeout(() => {
          fn(...args);
        }, wait);
      };
    }

    function syncSearchClearButton() {
      const hasKeyword = String(searchInput.value || '').trim().length > 0;
      clearSearchBtn.classList.toggle('is-visible', hasKeyword);
      clearSearchBtn.disabled = !hasKeyword;
    }

    function closeCustomSelect(root) {
      const trigger = root.querySelector('.custom-filter-trigger');
      root.classList.remove('is-open');
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
    }

    function closeAllCustomSelects(exceptRoot = null) {
      customSelectRoots.forEach((root) => {
        if (exceptRoot && root === exceptRoot) return;
        closeCustomSelect(root);
      });
    }

    function initCustomSelect({ nativeSelect, trigger, valueEl, menu }) {
      if (!nativeSelect || !trigger || !valueEl || !menu) return () => {};

      const root = trigger.closest('.custom-filter-select');
      if (!root) return () => {};

      function syncFromNative() {
        const selectedOption = nativeSelect.selectedOptions?.[0] || nativeSelect.options?.[0];
        valueEl.textContent = selectedOption ? selectedOption.textContent || '' : '';

        menu.querySelectorAll('.custom-filter-option').forEach((optionBtn) => {
          optionBtn.classList.toggle('is-active', optionBtn.dataset.value === nativeSelect.value);
        });
      }

      trigger.addEventListener('click', () => {
        const willOpen = !root.classList.contains('is-open');
        closeAllCustomSelects(root);
        root.classList.toggle('is-open', willOpen);
        trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      });

      menu.addEventListener('click', (event) => {
        const optionBtn = event.target.closest('.custom-filter-option');
        if (!optionBtn) return;
        const nextValue = optionBtn.dataset.value || '';
        if (nativeSelect.value !== nextValue) {
          nativeSelect.value = nextValue;
          nativeSelect.dispatchEvent(new Event('change', { bubbles: true }));
        } else {
          syncFromNative();
        }
        closeCustomSelect(root);
      });

      nativeSelect.addEventListener('change', syncFromNative);
      syncFromNative();

      return syncFromNative;
    }

    function animateVisibleCards(visibleCards) {
      if (prefersReducedMotion) return;

      visibleCards.forEach((card, index) => {
        card.classList.remove('filter-pop-in');
        card.style.removeProperty('--filter-delay');
        void card.offsetWidth;
        card.style.setProperty('--filter-delay', `${Math.min(index, 10) * 42}ms`);
        card.classList.add('filter-pop-in');
      });
    }

    // 将当前筛选条件写回 URL，方便分享与刷新保持状态
    function updateUrlParams() {
      const params = new URLSearchParams(window.location.search);
      const q = (searchInput.value || '').trim();
      const category = categoryFilter.value;
      const tag = tagFilter.value;

      if (q) params.set('q', q);
      else params.delete('q');

      if (category) params.set('category', category);
      else params.delete('category');

      if (tag) params.set('tag', tag);
      else params.delete('tag');

      if (page > 1) params.set('page', String(page));
      else params.delete('page');

      const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
      history.replaceState(null, '', nextUrl);
    }

    // 首次加载时从 URL 读取筛选参数
    function applyParamsFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q') || '';
      const category = params.get('category') || '';
      const tag = params.get('tag') || '';
      const fromPage = Number(params.get('page'));

      searchInput.value = q;
      syncSearchClearButton();
      if (Array.from(categoryFilter.options).some((o) => o.value === category)) {
        categoryFilter.value = category;
      }
      if (Array.from(tagFilter.options).some((o) => o.value === tag)) {
        tagFilter.value = tag;
      }

      customSelectSyncFns.forEach((sync) => sync());

      if (Number.isInteger(fromPage) && fromPage > 0) {
        page = fromPage;
      }
    }

    // 执行筛选（可控制是否重置页码）
    function applyFilter({ resetPage = true, animate = true } = {}) {
      const keyword = normalize(searchInput.value || '');
      const category = normalize(categoryFilter.value);
      const tag = normalize(tagFilter.value);

      filtered = cards.filter((card) => {
        const article = card.querySelector('.post-card');
        if (!article) return false;
        const text = normalize(article.dataset.search || card.textContent || '');
        const c = normalize(article.dataset.category || '');
        const tags = (article.dataset.tags || '').split(',').map((t) => normalize(t)).filter(Boolean);
        const hitKeyword = !keyword || text.includes(keyword);
        const hitCategory = !category || c === category;
        const hitTag = !tag || tags.includes(tag);
        return hitKeyword && hitCategory && hitTag;
      });

      if (resetPage) page = 1;
      render({ animate });
    }

    // 渲染分页控件
    function renderPager(totalPages) {
      pager.innerHTML = '';
      if (totalPages <= 1) return;

      const prev = document.createElement('a');
      prev.href = '#';
      prev.textContent = '上一页';
      prev.onclick = (e) => {
        e.preventDefault();
        if (page > 1) {
          page--;
          render();
        }
      };

      const info = document.createElement('span');
      info.className = 'pagination-info';
      info.textContent = `第 ${page} / ${totalPages} 页`;

      const next = document.createElement('a');
      next.href = '#';
      next.textContent = '下一页';
      next.onclick = (e) => {
        e.preventDefault();
        if (page < totalPages) {
          page++;
          render();
        }
      };

      if (page > 1) pager.appendChild(prev);
      pager.appendChild(info);
      if (page < totalPages) pager.appendChild(next);
    }

    // 根据当前页渲染可见卡片
    function render({ animate = true } = {}) {
      const totalPages = Math.max(1, Math.ceil(filtered.length / POSTS_PER_PAGE));
      if (page > totalPages) page = totalPages;
      const start = (page - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;
      const visibleCards = filtered.slice(start, end);

      cards.forEach((card) => (card.style.display = 'none'));
      visibleCards.forEach((card) => (card.style.display = 'block'));

      const hasResults = filtered.length > 0;
      emptyState.hidden = hasResults;
      grid.hidden = !hasResults;
      pager.hidden = !hasResults;

      if (animate && hasResults) {
        animateVisibleCards(visibleCards);
      }

      renderPager(totalPages);
      updateUrlParams();
      syncSearchClearButton();
    }

    // 事件绑定
    const debouncedSearchFilter = debounce(() => applyFilter({ resetPage: true }), SEARCH_DEBOUNCE_MS);

    searchInput.addEventListener('input', () => {
      syncSearchClearButton();
      debouncedSearchFilter();
    });

    clearSearchBtn.addEventListener('click', () => {
      if (!searchInput.value) return;
      searchInput.value = '';
      syncSearchClearButton();
      applyFilter({ resetPage: true });
      searchInput.focus();
    });

    categoryFilter.addEventListener('change', () => applyFilter({ resetPage: true }));
    tagFilter.addEventListener('change', () => applyFilter({ resetPage: true }));

    customSelectSyncFns.push(
      initCustomSelect({
        nativeSelect: categoryFilter,
        trigger: document.getElementById('categoryFilterTrigger'),
        valueEl: document.getElementById('categoryFilterValue'),
        menu: document.getElementById('categoryFilterMenu')
      }),
      initCustomSelect({
        nativeSelect: tagFilter,
        trigger: document.getElementById('tagFilterTrigger'),
        valueEl: document.getElementById('tagFilterValue'),
        menu: document.getElementById('tagFilterMenu')
      })
    );

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest('.custom-filter-select')) {
        closeAllCustomSelects();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeAllCustomSelects();
      }
    });

    // 初始化流程：先恢复 URL 状态，再执行筛选渲染
    applyParamsFromUrl();
    applyFilter({ resetPage: false, animate: false });
    }
  </script>
</BaseLayout>
