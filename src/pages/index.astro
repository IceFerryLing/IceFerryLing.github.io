---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, getAllCategories, getAllTags } from '../lib/posts';

const posts = getSortedPosts();
const latest = posts.slice(0, 6);
const categories = getAllCategories(posts).slice(0, 6);
const tags = getAllTags(posts).slice(0, 12);
---

<BaseLayout title="首页">
  <section class="relative overflow-hidden rounded-[28px] border border-white/10 bg-white/5 backdrop-blur-2xl shadow-2xl">
    <div class="absolute inset-0">
      <img src="/assets/images/hero-purple.svg" alt="紫色风格博客封面" class="h-full w-full object-cover opacity-70" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#0b0715]/80 via-[#1b1033]/70 to-[#2e1065]/50"></div>
    </div>
    <div class="relative z-10 px-8 py-12 md:px-12">
      <p class="text-xs tracking-[0.4em] text-purple-200/70">ICEFERRYLING BLOG</p>
      <h1 class="mt-4 text-3xl font-semibold text-white md:text-5xl">欢迎来到我的紫色星云博客</h1>
      <p class="mt-4 max-w-xl text-purple-100/80">记录代码、生活、灵感与每一次“啊哈”时刻。</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-purple-100/70">
        <span class="rounded-full border border-white/15 bg-white/10 px-4 py-1 backdrop-blur">暗紫 · 玻璃质感</span>
        <span class="rounded-full border border-white/15 bg-white/10 px-4 py-1 backdrop-blur">动态水滴</span>
        <span class="rounded-full border border-white/15 bg-white/10 px-4 py-1 backdrop-blur">鼠标轨迹</span>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-4 lg:grid-cols-3">
    <aside class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
      <h3 class="text-base font-semibold text-white">站点信息</h3>
      <p class="mt-3 text-sm text-purple-100/70">文章 {posts.length} 篇</p>
      <p class="text-sm text-purple-100/70">分类 {getAllCategories(posts).length} 个 · 标签 {getAllTags(posts).length} 个</p>
      <a href="/rss.xml" class="mt-4 inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs text-purple-100/80">订阅 RSS</a>
    </aside>
    <aside class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
      <h3 class="text-base font-semibold text-white">热门分类</h3>
      <div class="mt-3 flex flex-wrap gap-2">
        {categories.map((c) => <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-purple-100/70">{c.name} · {c.count}</span>)}
      </div>
    </aside>
    <aside class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-xl">
      <h3 class="text-base font-semibold text-white">热门标签</h3>
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((t) => <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-purple-100/70">#{t.name}</span>)}
      </div>
    </aside>
  </section>

  <section class="mt-10">
    <div class="flex items-center justify-between">
      <h2 class="text-xl font-semibold text-white">最新文章</h2>
      <a href="/archive/" class="text-sm text-purple-200/70 hover:text-purple-100">查看全部 →</a>
    </div>
    <div class="mt-4 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
