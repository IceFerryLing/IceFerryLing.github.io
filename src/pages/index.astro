---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, getAllCategories, getAllTags } from '../lib/posts';

const posts = getSortedPosts();
const latest = posts; // 如果你想显示全部，可以去掉 .slice(0, 6) 或者改成更大的数字
const categories = getAllCategories(posts).slice(0, 6);
const tags = getAllTags(posts).slice(0, 12);
---

<BaseLayout title="首页">
  <section class="hero-block glass-card animate__animated animate__fadeIn">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="announcement-pill"><i class="bi bi-megaphone-fill" aria-hidden="true"></i> 公告：欢迎来到我的数字花园，持续更新中</p>
      <p class="eyebrow">ICEFERRYLING BLOG</p>
      <h1>欢迎来到我的紫色星云博客</h1>
      <p class="subtitle">记录代码、生活、灵感与每一次快乐时刻。</p>
    </div>
  </section>

  <section class="quick-feature-grid mt-4">
    <a class="glass-card quick-feature" href="/archive/">
      <span class="feature-icon"><i class="bi bi-collection"></i></span>
      <div>
        <h3>归档导航</h3>
        <p>按分类、标签和关键词快速定位内容</p>
      </div>
    </a>
    <a class="glass-card quick-feature" href="/about/">
      <span class="feature-icon"><i class="bi bi-stars"></i></span>
      <div>
        <h3>关于本站</h3>
        <p>了解我、博客定位与未来更新计划</p>
      </div>
    </a>
    <a class="glass-card quick-feature" href="/rss.xml">
      <span class="feature-icon"><i class="bi bi-rss"></i></span>
      <div>
        <h3>RSS 订阅</h3>
        <p>用你习惯的阅读器追更，不错过每次灵感</p>
      </div>
    </a>
  </section>

  <section class="dashboard mt-4">
    <div class="row g-3">
      <div class="col-lg-4">
        <aside class="glass-card p-4 h-100">
          <h3 class="section-title">站点信息</h3>
          <p class="muted">文章 {posts.length} 篇</p>
          <p class="muted">分类 {getAllCategories(posts).length} 个 · 标签 {getAllTags(posts).length} 个</p>
          <div class="d-flex flex-wrap gap-2 mt-2">
            <a href="/rss.xml" class="btn btn-outline-light btn-sm" target="_blank" rel="noopener noreferrer">
              <i class="bi bi-rss-fill" aria-hidden="true"></i>
              <span class="ms-1">查看源</span>
            </a>
            <button type="button" class="btn btn-outline-light btn-sm" id="copyRssBtn" data-rss-copy>
              <i class="bi bi-clipboard-check" aria-hidden="true"></i>
              <span class="ms-1" data-rss-copy-label>复制地址</span>
            </button>
            <a
              href="https://feedly.com/i/subscription/feed/https://iceferryling.github.io/rss.xml"
              class="btn btn-outline-light btn-sm"
              target="_blank"
              rel="noopener noreferrer"
              id="feedlySubscribeBtn"
              data-feedly-subscribe
            >
              <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
              <span class="ms-1">Feedly 订阅</span>
            </a>
          </div>
          <p class="muted mt-2 mb-0" id="rssHintText">提示：可复制地址到任意 RSS 阅读器订阅。</p>
        </aside>
      </div>
      <div class="col-lg-4">
        <aside class="glass-card p-4 h-100">
          <h3 class="section-title">热门分类</h3>
          <div class="chip-wrap">
            {categories.map((c) => <span class="chip">{c.name} · {c.count}</span>)}
          </div>
        </aside>
      </div>
      <div class="col-lg-4">
        <aside class="glass-card p-4 h-100">
          <h3 class="section-title">热门标签</h3>
          <div class="chip-wrap">
            {tags.map((t) => <span class="chip">#{t.name}</span>)}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="post-list-wrap mt-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
      <h2 class="section-title mb-0">最新文章</h2>
      <a href="/archive/" class="link-light small">查看全部 →</a>
    </div>

    <div class="home-filter mt-3">
      <button class="chip is-active" type="button" data-home-filter="all">全部</button>
      {categories.map((c) => (
        <button class="chip" type="button" data-home-filter={c.name}>{c.name}</button>
      ))}
    </div>

    <div class="row g-4 mt-1">
      {latest.map((post) => (
        <div class="col-md-6 col-xl-4" data-home-card={post.category}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (() => {
      const rssUrl = `${window.location.origin}/rss.xml`;
      const copyRssBtn = document.querySelector('[data-rss-copy]');
      const copyRssLabel = document.querySelector('[data-rss-copy-label]');
      const rssHintText = document.getElementById('rssHintText');
      const feedlySubscribeBtn = document.querySelector('[data-feedly-subscribe]');

      if (feedlySubscribeBtn) {
        feedlySubscribeBtn.setAttribute('href', `https://feedly.com/i/subscription/feed/${encodeURIComponent(rssUrl)}`);
      }

      if (copyRssBtn && copyRssLabel) {
        copyRssBtn.addEventListener('click', async () => {
          let copied = false;
          try {
            await navigator.clipboard.writeText(rssUrl);
            copied = true;
          } catch {
            window.prompt('请手动复制 RSS 地址：', rssUrl);
            copied = false;
          }

          copyRssLabel.textContent = copied ? '已复制' : '复制失败';
          if (rssHintText) {
            rssHintText.textContent = copied ? `已复制：${rssUrl}` : '复制失败，请手动复制 /rss.xml';
          }

          window.setTimeout(() => {
            copyRssLabel.textContent = '复制地址';
            if (rssHintText) rssHintText.textContent = '提示：可复制地址到任意 RSS 阅读器订阅。';
          }, 1600);
        });
      }

      // 首页快筛：按分类切换“最新文章”列表显示
      const buttons = Array.from(document.querySelectorAll('[data-home-filter]'));
      const cards = Array.from(document.querySelectorAll('[data-home-card]'));
      if (!buttons.length || !cards.length) return;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function animateVisibleCards(visibleCards) {
        if (prefersReducedMotion) return;

        visibleCards.forEach((card, index) => {
          card.classList.remove('filter-pop-in');
          card.style.removeProperty('--filter-delay');
          void card.offsetWidth;
          card.style.setProperty('--filter-delay', `${Math.min(index, 8) * 48}ms`);
          card.classList.add('filter-pop-in');
        });
      }

      // 根据分类过滤卡片，并更新按钮激活态
      function setFilter(category) {
        buttons.forEach((btn) => {
          btn.classList.toggle('is-active', btn.dataset.homeFilter === category);
        });

        const visibleCards = [];
        cards.forEach((card) => {
          const matched = category === 'all' || card.dataset.homeCard === category;
          card.style.display = matched ? '' : 'none';
          if (matched) visibleCards.push(card);
        });

        animateVisibleCards(visibleCards);
      }

      // 绑定分类按钮点击事件
      buttons.forEach((btn) => {
        btn.addEventListener('click', (event) => {
          const rect = btn.getBoundingClientRect();
          const fallbackX = rect.width / 2;
          const fallbackY = rect.height / 2;
          const x = Number.isFinite(event.clientX) ? event.clientX - rect.left : fallbackX;
          const y = Number.isFinite(event.clientY) ? event.clientY - rect.top : fallbackY;
          btn.style.setProperty('--ripple-x', `${x}px`);
          btn.style.setProperty('--ripple-y', `${y}px`);

          btn.classList.remove('chip-pop', 'chip-ripple');
          // 强制重排，让连续点击也能重复触发动画
          void btn.offsetWidth;
          btn.classList.add('chip-pop', 'chip-ripple');

          clearTimeout(btn.__chipAnimTimer);
          btn.__chipAnimTimer = setTimeout(() => {
            btn.classList.remove('chip-pop', 'chip-ripple');
          }, 460);

          setFilter(btn.dataset.homeFilter || 'all');
        });
      });

      setFilter('all');
    })();
  </script>
</BaseLayout>
