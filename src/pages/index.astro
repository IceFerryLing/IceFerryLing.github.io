---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, getAllCategories, getAllTags } from '../lib/posts';

const posts = getSortedPosts();
const latest = posts.slice(0, 6);
const categories = getAllCategories(posts).slice(0, 6);
const tags = getAllTags(posts).slice(0, 12);
---

<BaseLayout title="首页">
  <section class="hero-block glass-card animate__animated animate__fadeIn">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="announcement-pill">📢 公告：欢迎来到我的数字花园，持续更新中</p>
      <p class="eyebrow">ICEFERRYLING BLOG</p>
      <h1>欢迎来到我的紫色星云博客</h1>
      <p class="subtitle">记录代码、生活、灵感与每一次“啊哈”时刻。</p>
      <div class="badge-row">
        <span class="glass-badge"><i class="bi bi-palette2 me-1"></i>暗紫 · 玻璃质感</span>
        <span class="glass-badge"><i class="bi bi-droplet-half me-1"></i>动态水滴</span>
        <span class="glass-badge"><i class="bi bi-mouse me-1"></i>鼠标轨迹</span>
      </div>
    </div>
  </section>

  <section class="quick-feature-grid mt-4">
    <a class="glass-card quick-feature" href="/archive/">
      <span class="feature-icon"><i class="bi bi-collection"></i></span>
      <div>
        <h3>归档导航</h3>
        <p>按分类、标签和关键词快速定位内容</p>
      </div>
    </a>
    <a class="glass-card quick-feature" href="/about/">
      <span class="feature-icon"><i class="bi bi-stars"></i></span>
      <div>
        <h3>关于本站</h3>
        <p>了解我、博客定位与未来更新计划</p>
      </div>
    </a>
    <a class="glass-card quick-feature" href="/rss.xml">
      <span class="feature-icon"><i class="bi bi-rss"></i></span>
      <div>
        <h3>RSS 订阅</h3>
        <p>用你习惯的阅读器追更，不错过每次灵感</p>
      </div>
    </a>
  </section>

  <section class="dashboard mt-4">
    <div class="row g-3">
      <div class="col-lg-4">
        <aside class="glass-card p-4 h-100">
          <h3 class="section-title">站点信息</h3>
          <p class="muted">文章 {posts.length} 篇</p>
          <p class="muted">分类 {getAllCategories(posts).length} 个 · 标签 {getAllTags(posts).length} 个</p>
          <a href="/rss.xml" class="btn btn-outline-light btn-sm mt-2">订阅 RSS</a>
        </aside>
      </div>
      <div class="col-lg-4">
        <aside class="glass-card p-4 h-100">
          <h3 class="section-title">热门分类</h3>
          <div class="chip-wrap">
            {categories.map((c) => <span class="chip">{c.name} · {c.count}</span>)}
          </div>
        </aside>
      </div>
      <div class="col-lg-4">
        <aside class="glass-card p-4 h-100">
          <h3 class="section-title">热门标签</h3>
          <div class="chip-wrap">
            {tags.map((t) => <span class="chip">#{t.name}</span>)}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="post-list-wrap mt-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
      <h2 class="section-title mb-0">最新文章</h2>
      <a href="/archive/" class="link-light small">查看全部 →</a>
    </div>

    <div class="home-filter mt-3">
      <button class="chip is-active" type="button" data-home-filter="all">全部</button>
      {categories.map((c) => (
        <button class="chip" type="button" data-home-filter={c.name}>{c.name}</button>
      ))}
    </div>

    <div class="row g-4 mt-1">
      {latest.map((post) => (
        <div class="col-md-6 col-xl-4" data-home-card={post.category}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (() => {
      const buttons = Array.from(document.querySelectorAll('[data-home-filter]'));
      const cards = Array.from(document.querySelectorAll('[data-home-card]'));
      if (!buttons.length || !cards.length) return;

      function setFilter(category) {
        buttons.forEach((btn) => {
          btn.classList.toggle('is-active', btn.dataset.homeFilter === category);
        });

        cards.forEach((card) => {
          const matched = category === 'all' || card.dataset.homeCard === category;
          card.style.display = matched ? '' : 'none';
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => setFilter(btn.dataset.homeFilter || 'all'));
      });
    })();
  </script>
</BaseLayout>
